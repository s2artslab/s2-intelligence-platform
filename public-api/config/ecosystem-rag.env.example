# Ecosystem RAG — add to public-api .env on r730
RAG_LIMIT=5
RAG_MAX_CHARS=3000
RAG_USE_EMBEDDINGS=0
RAG_EMBED_MODEL=nomic-embed-text
RAG_EMBED_WEIGHT=8

# Ingest / harvest (set KNOWLEDGE_INGEST_KEY in production)
KNOWLEDGE_INGEST_KEY=
BETA_CHAT_SECRET=

S2_HARVEST_DIR=/opt/s2-ecosystem/public-api/data/harvest
S2_HARVEST_DPO_PATH=/opt/s2-ecosystem/egregore-training/training_data/preferences/ake_dpo_harvest.jsonl
S2_PRIVATE_RAG_DIR=/opt/s2-ecosystem/public-api/data/private-rag
HARVEST_MIN_RATING=4
HARVEST_REQUIRE_RAG=0

# Beta worker (Cloudflare): route chat to gateway
S2_PUBLIC_API_URL=https://api.s2artslab.com

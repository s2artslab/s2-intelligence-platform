PORT=3020
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=s2-ake
OLLAMA_TEMPERATURE=0.2
OLLAMA_HOSTED_TEMPERATURE=0.2
OLLAMA_TOP_P=0.85
OLLAMA_REPEAT_PENALTY=1.12
OLLAMA_EXPLORATION_TEMPERATURE=0.2
OLLAMA_LORA_MODEL=s2-ake-lora
OLLAMA_PREFER_LORA=true

UNIFIED_EGREGORE_URL=http://127.0.0.1:8100
HOSTED_PREFER_UNIFIED_LORA=false
HOSTED_EGREGORE_ID=ake
UNIFIED_EGREGORE_TIMEOUT_MS=300000

HOSTED_DEFAULT_MAX_TOKENS=800
HOSTED_LONG_FORM_MAX_TOKENS=4096
HOSTED_LONG_FORM_PREFER_OLLAMA=true
LONG_FORM_OUTLINE_EXPAND=true
LONG_FORM_SECTION_MAX_TOKENS=600
LONG_FORM_OUTLINE_MAX_TOKENS=400
UNIFIED_LONG_FORM_MAX_TOKENS=512

HOSTED_REQUIRE_BILLING=true
BILLING_API_URL=https://s2-billing.s2artslab.workers.dev
BILLING_PRODUCT_ID=psla-hosted
DOCUMENT_INTELLIGENCE_URL=http://127.0.0.1:8099
LAB_HOSTED_UNLOCK=true
LAB_UNIFIED_CHAT=true
S2_KNOWLEDGE_DIR=./knowledge
RAG_LIMIT=5
RAG_MAX_CHARS=3000

# Morphic interval policy (ops knob; public 1.58D = metaphor per claims register)
MORPHIC_RESONANCE=1.58
MORPHIC_INTERVAL_START=1.58
MORPHIC_INTERVAL_END=1.618
MORPHIC_TEMP_MIN=0.1
MORPHIC_TEMP_MAX=0.32
MORPHIC_TEMP_BLEND=0.3
MORPHIC_TEMP_BLEND_MIN=0.2
MORPHIC_TEMP_BLEND_SPAN=0.3
MORPHIC_RAG_LIMIT_MIN=4
MORPHIC_RAG_LIMIT_MAX=12
MORPHIC_RAG_CHARS_MIN=2400
MORPHIC_RAG_CHARS_MAX=4800
INFERENCE_DEPTH_MULT_MIN=0.75
INFERENCE_DEPTH_MULT_SPAN=0.5

# PSLA ensemble: off by default (morphic-only). Opt in per request: ensemble: true
# Cheap mode = 1 LLM + general RAG disagreement (default when opted in)
ENSEMBLE_PSLA_COLLAPSE=false
ENSEMBLE_DEFAULT_MODE=cheap
ENSEMBLE_CHEAP_GENERAL_MAX_CHARS=1200
ENSEMBLE_DISAGREEMENT_THRESHOLD=0.28
ENSEMBLE_HOLD_THRESHOLD=0.42
CONSCIOUSNESS_SERVER_LABEL=r730-production
EGREGORE_COUNT=9

# EgregoreLab — dual-lane profile registry (hosted + BitNet readiness)
EGREGORE_PROFILES_PATH=/root/ninefold-studio-clean/egregorelab/config/unified_egregore_profiles.json
EGREGORE_INFERENCE_MANIFEST=/opt/s2-ecosystem/egregore-training/training_data/egregore_inference_manifest.json
BITNET_EGREGORE_REGISTRY=/opt/s2-ecosystem/egregore-training/training_data/bitnet_adapters/bitnet_egregore_registry.json

# BitNet 1.58 experimental lane (specialist tasks — production spine remains 4-bit Ollama)
BITNET_ENABLED=true
BITNET_BASE_URL=http://127.0.0.1:8120
BITNET_MODEL=bitnet-b1.58-2B-4T
# QVAC llama-finetune-lora (train); sidecar uses bitnet.cpp i2_s separately
BITNET_MODEL_GGUF=/opt/qvac-fabric-llm.cpp/models/BitNet-b1.58-2B-4T-tq2/dl-gianni-cor/bitnet_b1_58-xl-TQ2_0/bitnet_b1_58-xl-TQ2_0.gguf
BITNET_TIMEOUT_MS=120000
BITNET_RESEARCH_DATA_DIR=./data

CORS_ORIGIN=*

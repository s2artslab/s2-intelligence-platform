PORT=3010

# Mind Games plugin (Temple / InnerPath strength profile sync)
# MIND_GAMES_PLUGIN_TOKEN=
# VITALSYNC_INGEST_API_URL=https://data-ingest.s2artslab.com
# VITALSYNC_INGEST_API_KEY=

# Hosted Ollama (recommended: localhost on r730 or SSH tunnel from workstation)
# Do not assume LAN direct access to 192.168.1.78:11434; firewall policy may block it.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=s2-ake
OLLAMA_TEMPERATURE=0.2
OLLAMA_HOSTED_TEMPERATURE=0.2
OLLAMA_TOP_P=0.85
OLLAMA_REPEAT_PENALTY=1.12
# Optional — only after 7B Tier C + LORA_TO_OLLAMA.md; production uses s2-ake until then:
OLLAMA_LORA_MODEL=s2-ake-lora
OLLAMA_PREFER_LORA=false

# Trained egregore LoRAs (r730 Flask unified service)
UNIFIED_EGREGORE_URL=http://192.168.1.78:8100

# Strategist dashboard hub Worker — POST /api/public/strategist/generate (same key as X-Sharayah-Digest on hub)
# STRATEGIST_HUB_API_KEY=
# SHARAYAH_DIGEST_KEY=
# false until tier-c-eval-gate-r730.py passes — see docs/AKE_LORA_STATUS.md
HOSTED_PREFER_UNIFIED_LORA=false
HOSTED_EGREGORE_ID=ake
UNIFIED_EGREGORE_TIMEOUT_MS=120000

# Long-form + synthesis voice (docs/AKE_LONG_FORM.md)
HOSTED_DEFAULT_MAX_TOKENS=800
HOSTED_LONG_FORM_MAX_TOKENS=4096
HOSTED_LONG_FORM_PREFER_OLLAMA=true
LONG_FORM_OUTLINE_EXPAND=true
LONG_FORM_SECTION_MAX_TOKENS=600
LONG_FORM_OUTLINE_MAX_TOKENS=400
UNIFIED_LONG_FORM_MAX_TOKENS=512

# BYOK lab fallback (single-tenant dev only)
# GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Collective knowledge RAG (Layer 5)
S2_KNOWLEDGE_DIR=./knowledge
RAG_LIMIT=5
RAG_MAX_CHARS=3000

# Morphic interval inference (see docs/MORPHIC_ENSEMBLE_GATEWAY.md)
MORPHIC_RESONANCE=1.58
MORPHIC_INTERVAL_START=1.58
MORPHIC_INTERVAL_END=1.618
MORPHIC_TEMP_MIN=0.1
MORPHIC_TEMP_MAX=0.38
MORPHIC_TEMP_BLEND=0.35
MORPHIC_TEMP_BLEND_MIN=0.2
MORPHIC_TEMP_BLEND_SPAN=0.3
MORPHIC_RAG_LIMIT_MIN=3
MORPHIC_RAG_LIMIT_MAX=12
MORPHIC_RAG_CHARS_MIN=2200
MORPHIC_RAG_CHARS_MAX=4800
INFERENCE_DEPTH_MULT_MIN=0.75
INFERENCE_DEPTH_MULT_SPAN=0.5
# false = morphic-only production; true = auto ensemble on all PSLA (lab only)
ENSEMBLE_PSLA_COLLAPSE=false
ENSEMBLE_DEFAULT_MODE=cheap
ENSEMBLE_CHEAP_GENERAL_MAX_CHARS=1200
ENSEMBLE_DISAGREEMENT_THRESHOLD=0.28
ENSEMBLE_HOLD_THRESHOLD=0.42
CONSCIOUSNESS_SERVER_LABEL=r730-gateway
EGREGORE_COUNT=9

# BitNet b1.58 experimental lane (see docs/BITNET_EXPERIMENTAL_LANE.md)
BITNET_ENABLED=false
BITNET_BASE_URL=http://127.0.0.1:8120
BITNET_MODEL=bitnet-b1.58-2B-4T
BITNET_TIMEOUT_MS=120000
BITNET_RESEARCH_DATA_DIR=./data

# Continuity layers (see docs/AKE_CONTINUITY_ARCHITECTURE.md)
S2_CANON_DIR=./canon
CANON_MAX_CHARS=1200
S2_DISCOURSE_INDEX=./data/discourse-index.json
S2_RETRIEVAL_INDEX=./data/retrieval-index.json
S2_TENSION_STORE=./data/tensions
TENSION_MAX_CHARS=800
S2_REFLECTION_ON_CHAT=true
# Optional — protect memory admin routes in production
# MEMORY_API_KEY=

# Billing for hosted tier (production)
HOSTED_REQUIRE_BILLING=false
BILLING_API_URL=https://s2-billing.s2artslab.workers.dev
BILLING_API_KEY=
BILLING_PRODUCT_ID=psla-hosted

# Dev: allow hosted without subscription check
LAB_HOSTED_UNLOCK=true
# Standalone /lab/ake-unified-lora chat (direct :8100; also enabled when LAB_HOSTED_UNLOCK=true)
LAB_UNIFIED_CHAT=true

# Comma-separated browser origins, or * (dev only). Behind nginx use BEHIND_NGINX_CORS=true.
CORS_ORIGIN=https://psla.s2artslab.com,https://s2artslab.com
BEHIND_NGINX_CORS=false

# Public Document Intelligence (Cloudflare: document-intelligence.s2artslab.com)
DOCUMENT_INTELLIGENCE_URL=https://document-intelligence.s2artslab.com
